# Copy to .env and adjust, or export these in your shell / systemd / Docker.
# All variables use the ACCOUNTING_ prefix.

# --- HTTP server ---
# Address to listen on (host:port or :port for all interfaces).
ACCOUNTING_HTTP_ADDR=:8080

# --- Database ---
# Path to the SQLite file (parent directory is created if needed).
ACCOUNTING_DB=data/app.db

# --- Authentication ---
# Required in production: login password for the web UI.
ACCOUNTING_PASSWORD=changeme

# Secret for signing the session cookie (long random string; not the same as the password).
ACCOUNTING_AUTH_KEY=

# --- Display ---
# IANA time zone for showing dates/times. Data in the database is stored in UTC.
# Examples: Asia/Tehran, Europe/Berlin, America/New_York, UTC
ACCOUNTING_TZ=Asia/Tehran

# Default UI language when the user has not chosen EN/FA yet (browser cookie: acct_lang).
# en | fa
ACCOUNTING_LANG=fa

# --- Optional ---
# Override the gold spot price JSON API (default: Talasea getGoldPrice).
# ACCOUNTING_GOLD_API_URL=https://api.talasea.ir/api/market/getGoldPrice
# Rial per Toman for the gold spot (Iran: 1 Toman = 10 Rial).
# ACCOUNTING_GOLD_RIAL_PER_TOMAN=10
# Optional extra multiplier on mg × Toman/mg × Rial/Toman (default: 1).
# ACCOUNTING_GOLD_PRICE_SCALE=1
# Deprecated alias for ACCOUNTING_GOLD_PRICE_SCALE:
# ACCOUNTING_GOLD_GRAM_RIAL_SCALE=1
